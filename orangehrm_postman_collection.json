{
  "info": {
    "name": "OrangeHRM Login API Tests",
    "description": "Postman Collection for testing the OrangeHRM Login endpoint.\n\nAssumptions made:\n1. The login endpoint accepts POST requests with form-data or urlencoded format (using `username` and `password` variables).\n2. The default credentials for the happy path are Admin / admin123.\n3. The endpoint may redirect upon success (302) or return a 200 with an error wrapper if invalid. Assertions cover these possibilities.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Success (Happy Path)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "Admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/web/index.php/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "web",
                "index.php",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Validate that the server responds with a 200 OK or 302 Redirect",
                  "pm.test('Status is 200 or 302', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "Admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "wrongpassword",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/web/index.php/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "web",
                "index.php",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Expecting failed login to return 200 OK (error HTML response) or 401 Unauthorized",
                  "pm.test('Status code reflects error (200 or 401)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "});",
                  "// Check for an error message in the body if it fails softly",
                  "pm.test('Response contains error clue', function () {",
                  "    pm.expect(pm.response.text()).to.include('Invalid credentials');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Missing Credentials (Boundary)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/web/index.php/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "web",
                "index.php",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response Code reflects error (400 Bad Request or 200)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Empty Request Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/web/index.php/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "web",
                "index.php",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response Code reflects missing body parameters', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://opensource-demo.orangehrmlive.com",
      "type": "string"
    }
  ]
}
